# API
NEXT_PUBLIC_API_URL=https://your-api-url-here

# OneTrust Cookie Consent (WEP-6)
# Domain script ID from the OneTrust admin portal (provided by Liberty Blume)
# Required for cookie consent banner to appear. Without this, no banner is shown.
NEXT_PUBLIC_ONETRUST_DOMAIN_ID=your-onetrust-domain-id-here

# Google Analytics 4 (WEP-16)
# GA4 Measurement ID (provided by Liberty Blume). Format: G-XXXXXXXXXX
# GA4 only loads when the user grants Performance consent (OneTrust C0003).
# Without this value, GA4 is silently disabled.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google reCAPTCHA Enterprise site key
# Register the key at https://console.cloud.google.com/security/recaptcha
# Required for signatory mutation endpoints to include X-ReCaptcha-Token.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-enterprise-site-key
